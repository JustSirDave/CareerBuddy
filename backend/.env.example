# CareerBuddy — Environment Variables
# Copy to .env and fill in real values before running locally.

# Application
APP_ENV=local
APP_PORT=8000
PUBLIC_URL=http://localhost:8000

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=CareerBuddyBot
TELEGRAM_WEBHOOK_SECRET=          # Required in production (random string ≥ 32 chars)
ADMIN_TELEGRAM_IDS=               # Comma-separated Telegram user IDs

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/buddy

# Redis
REDIS_URL=redis://redis:6379/0

# AI / LLM
OPENAI_API_KEY=

# Cloud Storage (Cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Usage limits
MONTHLY_DOC_LIMIT=5               # Max documents per user per calendar month

# Feedback
FEEDBACK_CHANNEL_ID=              # Telegram channel/chat ID to forward bad feedback to

# Security
DOWNLOAD_SECRET=                  # Required in production (random string ≥ 32 chars)
